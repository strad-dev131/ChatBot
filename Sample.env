# Telegram API Configuration (Required)
# Get these from https://my.telegram.org
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Bot Token (Required)
# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Database Configuration (Required)
# MongoDB Connection URL - Get free database from https://cloud.mongodb.com/
MONGO_URL=mongodb://username:password@host:port/database_name

# Bot Owner Configuration (Required)
# Your Telegram User ID - Get from @userinfobot
OWNER_ID=your_telegram_user_id
OWNER_USERNAME=your_telegram_username

# ENHANCED: AI Configuration (Required for Girl Personality)
# OpenRouter API Key for unlimited AI responses - Get from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Personality Settings (Optional)
# Choose: girlfriend, flirty, cute, sweet
AI_PERSONALITY=girlfriend
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
ENABLE_AI_CHAT=True
MAX_AI_TOKENS=150

# Support & Updates (Optional)
# Support group and update channel usernames
SUPPORT_GRP=TeamsXchat
UPDATE_CHNL=TeamXUpdate

# Optional Configuration
# String session for userbot functionality (Optional)
STRING_SESSION=your_string_session_here

# Log Group ID (Optional)
# Create a group and get its ID using @MissRose_bot
LOG_GROUP_ID=your_log_group_id

# Advanced Configuration (Optional)
# Webhook URL for deployment (Optional)
WEBHOOK_URL=

# Port for webhook (Optional)
PORT=8080

# Heroku App Name (For Heroku deployment only)
HEROKU_APP_NAME=your_heroku_app_name

# Timezone Configuration (Optional)
TIMEZONE=Asia/Kolkata

# Debug Mode (Optional)
# Set to True for debugging, False for production
DEBUG=False

# Feature Flags (Optional)
ENABLE_CLONE_FEATURE=True
ENABLE_BROADCAST_FEATURE=True
ENABLE_CHATBOT_FEATURE=True
ENABLE_LANGUAGE_DETECTION=True

# Rate Limiting (Optional)
RATE_LIMIT_MESSAGES=30
RATE_LIMIT_WINDOW=60

# Clone Configuration (Optional)
MAX_CLONES_PER_USER=5
ALLOW_BOT_CLONING=True

# Broadcast Configuration (Optional)
BROADCAST_DELAY=0.1
MAX_BROADCAST_MESSAGES=1000

# Database Configuration (Optional)
DB_NAME=Anonymous
CHATS_COLLECTION=chats
USERS_COLLECTION=users
CLONES_COLLECTION=clones

# Performance Configuration (Optional)
MONGODB_MAX_CONNECTIONS=100
CONCURRENT_UPDATES=True

# Security Configuration (Optional)
# Comma-separated list of authorized user IDs
AUTHORIZED_USERS=

# Language Configuration (Optional)
DEFAULT_LANGUAGE=en
ENABLE_AUTO_LANG_DETECT=True

# ===========================================
# 🚨 IMPORTANT SETUP INSTRUCTIONS 🚨
# ===========================================

# 1. Get OpenRouter API Key (FREE):
#    - Visit: https://openrouter.ai/
#    - Sign up with your email
#    - Go to Keys section
#    - Create new key
#    - Copy and paste above

# 2. Required Variables:
#    - API_ID & API_HASH (from my.telegram.org)
#    - BOT_TOKEN (from @BotFather)
#    - MONGO_URL (from MongoDB Atlas)
#    - OWNER_ID (your Telegram user ID)
#    - OPENROUTER_API_KEY (for AI girl personality)

# 3. AI Personalities Available:
#    - girlfriend: Loving, caring girlfriend responses
#    - flirty: Playful, flirty, teasing responses
#    - cute: Sweet, innocent, bubbly responses  
#    - sweet: Kind, gentle, caring responses

# 4. Free AI Models Available:
#    - meta-llama/llama-3.1-8b-instruct:free
#    - microsoft/phi-3-mini-128k-instruct:free
#    - google/gemma-2-9b-it:free
